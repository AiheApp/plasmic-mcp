{
  "name": "plasmic-mcp",
  "version": "0.1.0",
  "description": "MCP server for headless Plasmic (self-hosted) project ops: list/create/clone/update/publish projects, devflags, permissions, and Copilot UI generation. Auth via session + CSRF.",
  "type": "module",
  "bin": {
    "plasmic-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "prompts"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "start:http": "node dist/http.js",
    "start:page-api": "node dist/http-server.js",
    "bench": "tsx bench/run.ts",
    "assist": "tsx src/assist/cli.ts",
    "assist:server": "node dist/assist/server.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.109.1",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "dotenv": "^16.4.5",
    "zod": "^3.23.8",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=20"
  }
}
