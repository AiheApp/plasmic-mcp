{
  "name": "plasmic-mcp",
  "version": "0.1.0",
  "description": "MCP server for headless Plasmic (self-hosted) project ops: list/create/clone/update/publish projects, devflags, permissions, and Copilot UI generation. Auth via session + CSRF.",
  "type": "module",
  "bin": {
    "plasmic-mcp": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "start:http": "node dist/http-server.js",
    "gen:tokens": "tsx scripts/gen-tokens.ts",
    "canvas:bench": "tsx scripts/canvas-bench.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "dotenv": "^16.4.5",
    "playwright": "^1.61.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=20"
  }
}
