# Self-hosted Plasmic instance base URL (no trailing slash).
PLASMIC_HOST=https://studio.aihe.dev

# Credentials for the session login (POST /api/v1/auth/login).
# Prefer a dedicated service account. Never commit the real .env.
PLASMIC_EMAIL=service-account@example.com
PLASMIC_PASSWORD=change-me

# Optional: override the User-Agent sent on every request. Must NOT match the
# Cloudflare WAF block rule (the UA-1010 block). A non-default UA is set by
# default; override only if needed.
# PLASMIC_USER_AGENT=plasmic-mcp/0.1

# ---- plasmic-page-api (HTTP seeding service, src/http-server.ts) ----
# Bearer secret required on all POST routes.
ADD_PAGE_SECRET=change-me
# PORT=8765

# ---- design-assist (agent loop CLI / HTTP service) ----
# Anthropic API key used by the agent loop.
# ANTHROPIC_API_KEY=sk-ant-…
# Runtime model for the loop (default claude-sonnet-5).
# ASSIST_MODEL=claude-sonnet-5
# Bearer token required by the HTTP service (assist:server) on every route
# except /healthz. Generate with: openssl rand -hex 32
# ASSIST_BEARER_TOKEN=change-me
# Port for the HTTP service (default 8766).
# ASSIST_PORT=8766
# Designer-facing Studio URL for review links, when PLASMIC_HOST is an
# internal address (e.g. http://10.0.2.2:3003 on the VPS).
# ASSIST_PUBLIC_STUDIO_URL=https://studio.aihe.dev

# ---- canvas tools (plasmic_insert_html / _template / _doctor / _screenshot) ----
# Project whose style tokens seed the template allowlist (npm run gen:tokens).
# PLASMIC_TOKENS_PROJECT=sG6vJRAEtrLuNL7jYb3Tpk
# Plasmic Cloud auth: Playwright storage-state JSON. Mint/refresh it headlessly
# with `npm run cloud:login` (uses PLASMIC_CLOUD_EMAIL/PASSWORD below). When
# set, it replaces cookie-jar injection for the canvas browser.
# PLASMIC_STORAGE_STATE=.plasmic/cloud-state.json

# Plasmic CLOUD (studio.plasmic.app) login for `npm run cloud:login`.
# Values: ClickUp passwords/links doc, "studio.plasmic.app" row. Never commit.
# PLASMIC_CLOUD_EMAIL=service-account@example.com
# PLASMIC_CLOUD_PASSWORD=change-me
# PLASMIC_CLOUD_HOST=https://studio.plasmic.app
