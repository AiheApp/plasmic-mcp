# Plasmic Studio base URL (no trailing slash).
#   Self-hosted:   https://studio.aihe.dev
#   Plasmic Cloud: https://studio.plasmic.app
# The canvas-browser tools (auto-launch, auth, frame chain, studioCtx.paste) are
# VERIFIED on BOTH — only this host + the credentials below need to change.
PLASMIC_STUDIO_HOST=https://studio.aihe.dev

# Studio API credentials (for project reads, token management, publish)
# Get these from <studio host> -> Account -> API tokens
PLASMIC_API_USER=your@email.com
PLASMIC_API_TOKEN=your_personal_api_token

# Email/password login — lets canvas-browser auto-authenticate a cold-started
# Chrome (API login + session-cookie inject). Required for unattended cloud or
# self-hosted runs where no Studio tab is already logged in.
PLASMIC_EMAIL=your@email.com
PLASMIC_PASSWORD=your_password

# Project to work with
PLASMIC_PROJECT_ID=your_project_id

# Project token for Loader API reads (find in project settings)
PLASMIC_PROJECT_TOKEN=your_project_token

# Write API secret token — for write_create_component, write_update_component, write_update_tokens
# On Plasmic Cloud this requires enterprise access. Self-hosted instances may differ.
# Different from the public PLASMIC_PROJECT_TOKEN above.
PLASMIC_PROJECT_SECRET_TOKEN=your_project_secret_token

# CMS (optional — only needed for CMS tools)
PLASMIC_CMS_DATABASE_ID=your_database_id
PLASMIC_CMS_PUBLIC_TOKEN=your_public_token
PLASMIC_CMS_SECRET_TOKEN=your_secret_token
