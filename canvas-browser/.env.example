# Plasmic Studio URL (no trailing slash)
PLASMIC_STUDIO_HOST=https://studio.aihe.dev

# Chrome remote debugging URL
# Start Chrome with: google-chrome --remote-debugging-port=9222
# Or on Mac: open -a "Google Chrome" --args --remote-debugging-port=9222
PLASMIC_CHROME_DEBUG_URL=http://localhost:9222

# Default project ID (tools also accept projectId as a parameter)
PLASMIC_PROJECT_ID=your_project_id
